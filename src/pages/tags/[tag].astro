---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allTags = [...new Set(posts.flatMap(p => p.data.tags))];
  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
---

<BaseLayout title={`${tag} - 标签`}>
  <div class="container">
    <div class="page-header">
      <h1>{tag} <span style="font-size:0.9rem; color: var(--text-secondary); font-weight:normal;">({posts.length})</span></h1>
      <a href="/tags" style="font-size:0.85rem; color: var(--text-secondary);">← 所有标签</a>
    </div>
    <ul class="post-list">
      {posts.map(post => (
        <li class="post-list-item">
          <div style="flex:1; min-width:0;">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-list-title">
              {post.data.title}
            </a>
          </div>
          <span class="post-list-date">{formatDate(post.data.pubDate)}</span>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
