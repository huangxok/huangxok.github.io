---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '越努力，越幸运！' } = Astro.props;
const currentPath = Astro.url.pathname;

const allPosts = await getCollection('blog');
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))];
const postCount = allPosts.length;
const tagCount = allTags.length;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
</head>
<body>
  <!-- APlayer 音乐播放器容器（全站左下角吸底） -->
  <div id="aplayer-global"></div>

  <div class="layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-inner">
        <!-- Site Identity -->
        <div class="site-meta">
          <a href="/" class="site-title">HKBlog</a>
          <p class="site-subtitle">越努力，越幸运</p>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav">
          <ul>
            <li>
              <a href="/" class={currentPath === '/' ? 'active' : ''}>
                <span>📄</span>首页
              </a>
            </li>
            <li>
              <a href="/tags" class={currentPath.startsWith('/tags') ? 'active' : ''}>
                <span>🏷️</span>标签
              </a>
            </li>
            <li>
              <a href="/music" class={currentPath === '/music' ? 'active' : ''}>
                <span>🎵</span>音乐
              </a>
            </li>
            <li>
              <a href="/about" class={currentPath === '/about' ? 'active' : ''}>
                <span>👤</span>关于
              </a>
            </li>
          </ul>
        </nav>

        <!-- Site Stats -->
        <div class="site-state">
          <div class="site-state-item">
            <a href="/">
              <span class="state-count">{postCount}</span>
              <span class="state-label">文章</span>
            </a>
          </div>
          <div class="site-state-item">
            <a href="/tags">
              <span class="state-count">{tagCount}</span>
              <span class="state-label">标签</span>
            </a>
          </div>
        </div>

        <!-- External Links -->
        <div class="sidebar-links">
          <ul>
            <li>
              <a href="https://github.com/huangxok" target="_blank" rel="noopener" class="ext-link">
                <span>🐙</span>GitHub
              </a>
            </li>
          </ul>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main">
      <slot />
      <footer>
        <div class="container">
          <p>&copy; {new Date().getFullYear()} HKBlog · 越努力，越幸运</p>
        </div>
      </footer>
    </main>
  </div>

  <!-- APlayer 样式 -->
  <style is:global>
    .aplayer .aplayer-lrc p {
      font-size: 12px;
      font-weight: 700;
      line-height: 16px !important;
    }
    .aplayer .aplayer-lrc p.aplayer-lrc-current {
      font-size: 15px;
      color: #42b983;
    }
    /* 左下角吸底模式：默认隐藏，hover 展开 */
    .aplayer.aplayer-fixed.aplayer-narrow .aplayer-body {
      left: -66px !important;
    }
    .aplayer.aplayer-fixed.aplayer-narrow .aplayer-body:hover {
      left: 0px !important;
    }
  </style>

  <!-- APlayer + 自定义 API 加载（不依赖 Meting.js） -->
  <script>
    (function() {
      // 1. 加载 APlayer CSS
      const css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = 'https://cdn.jsdelivr.net/npm/aplayer@1.10.1/dist/APlayer.min.css';
      document.head.appendChild(css);

      // 2. 加载 APlayer JS
      const aplayerScript = document.createElement('script');
      aplayerScript.src = 'https://cdn.jsdelivr.net/npm/aplayer@1.10.1/dist/APlayer.min.js';
      aplayerScript.onload = function() {
        // 3. APlayer 加载完成，从 api.injahow.cn 获取歌单
        fetch('https://api.injahow.cn/meting/?server=netease&type=playlist&id=18726943')
          .then(res => res.json())
          .then(data => {
            if (!data || !Array.isArray(data)) {
              console.error('获取歌单失败');
              return;
            }
            
            // 转换数据格式为 APlayer 所需格式
            const audio = data.map(song => ({
              name: song.name,
              artist: song.artist,
              url: song.url,
              cover: song.pic,
              lrc: song.lrc
            }));
            
            // 4. 初始化 APlayer
            const ap = new APlayer({
              container: document.getElementById('aplayer-global'),
              fixed: true,
              autoplay: false,
              theme: '#42b983',
              loop: 'all',
              order: 'random',
              preload: 'auto',
              volume: 0.7,
              listFolded: true,
              listMaxHeight: 300,
              audio: audio
            });
          })
          .catch(err => console.error('播放器初始化失败:', err));
      };
      aplayerScript.onerror = function() {
        console.error('APlayer 加载失败');
      };
      document.body.appendChild(aplayerScript);
    })();
  </script>
</body>
</html>
