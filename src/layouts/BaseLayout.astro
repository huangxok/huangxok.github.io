---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '技术博客，记录前端开发学习笔记、技术踩坑和生活感悟' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="site-name">HKBlog</a>
      <nav>
        <a href="/" class={currentPath === '/' ? 'active' : ''}>首页</a>
        <a href="/tags" class={currentPath.startsWith('/tags') ? 'active' : ''}>标签</a>
        <a href="/about" class={currentPath === '/about' ? 'active' : ''}>关于</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="container">
      <p>&copy; {new Date().getFullYear()} HKBlog · 努力不一定成功，放弃一定会很轻松</p>
    </div>
  </footer>
</body>
</html>
